# ── 数据库 ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/choreo

# ── 模型 API 密钥（在 config.yaml 里用 $KEY_NAME 引用）──────────────
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── GitHub（知识来源拉取 + OAuth 登录）──────────────────────────────
GITHUB_TOKEN=               # 可选，提高 GitHub API 速率限制（5000/h vs 60/h）
GITHUB_CLIENT_ID=           # GitHub OAuth 登录（可选）
GITHUB_CLIENT_SECRET=

# ── 飞书 Bot（可选，接入飞书消息平台）───────────────────────────────
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_NOTIFY_CHAT_ID=      # agent 主动推送通知的目标 chat_id
FEISHU_WEBHOOK_URL=          # 旧版群机器人 Webhook（不推荐）

# ── 邮件通知（可选）──────────────────────────────────────────────────
SMTP_HOST=                   # QQ: smtp.qq.com  163: smtp.163.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=               # 授权码（非登录密码）

# ── Web 搜索（可选）──────────────────────────────────────────────────
TAVILY_API_KEY=              # 设置后自动启用 Tavily 搜索

# ── Daytona 云沙箱（可选）────────────────────────────────────────────
DAYTONA_API_KEY=

# ── LangSmith 链路追踪（可选）────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=choreo-dev
LANGSMITH_TRACING=false

# ── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

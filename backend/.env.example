# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/choreo

CHOREO_MAX_LLM_CALLS=20

# LangSmith（可选，用于 trace）
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=choreo-dev
LANGSMITH_TRACING=false

# 飞书 Bot（可选，见 README「接入飞书」）
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_NOTIFY_CHAT_ID=      # agent 主动推送通知的目标 chat_id（首次与 Bot 对话后从 channels 表查询）
FEISHU_WEBHOOK_URL=          # 旧版群机器人 Webhook，不推荐

# 邮件通知（可选）
SMTP_HOST=                   # QQ邮箱: smtp.qq.com  163邮箱: smtp.163.com
SMTP_PORT=465
SMTP_USER=                   # 你的邮箱地址
SMTP_PASSWORD=               # 授权码（非登录密码）

# 沙箱
CHOREO_SANDBOX_TIMEOUT=120
CHOREO_SANDBOX_WORKDIR=./sandbox

# Auth
JWT_SECRET=change-me-in-production
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# GitHub OAuth（可选）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
